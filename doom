#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Load .env
if [ -f .env ]; then
  export $(grep -v '^#' .env | xargs)
fi

usage() {
  echo "Usage: doom <command>"
  echo ""
  echo "Commands:"
  echo "  up        Start local Supabase"
  echo "  down      Stop local Supabase"
  echo "  migrate   Run Drizzle migrations"
  echo "  wipe      Drop all tables and re-migrate"
  echo "  sync      Trigger daily cron sync"
  echo "  dev       Start the dev server"
  echo "  status    Show Supabase status"
  echo "  studio    Open Supabase Studio URL"
  echo "  db        Open psql shell in the database"
}

cmd_up() {
  supabase start
}

cmd_down() {
  supabase stop
}

cmd_migrate() {
  npx drizzle-kit migrate
}

cmd_wipe() {
  echo "Dropping all tables..."
  docker exec supabase_db_doomsd psql -U postgres -d postgres -c "
    DROP TABLE IF EXISTS daily_index CASCADE;
    DROP TABLE IF EXISTS daily_scores CASCADE;
    DROP TABLE IF EXISTS incidents CASCADE;
    DROP TABLE IF EXISTS providers CASCADE;
    DROP SCHEMA IF EXISTS drizzle CASCADE;
  "
  echo "Re-running migrations..."
  npx drizzle-kit migrate
  echo "Done. Clean database ready."
}

cmd_sync() {
  local secret="${CRON_SECRET:-change-me-in-production}"
  local port="${DEV_PORT:-5173}"
  local url="http://localhost:${port}/api/cron"

  echo "Syncing Doomsd.ai index..."
  echo "  → Hitting ${url}"
  echo "  → This will backfill from Jan 1, 2026 on first run (may take a minute)"
  echo ""

  local start_time=$(date +%s)
  local response
  if ! response=$(curl -s -w "\n%{http_code}" -X POST "${url}" \
    -H "Authorization: Bearer ${secret}" \
    -H "Content-Type: application/json" 2>&1); then
    echo "✗ Could not connect — is the dev server running? (./doom dev)"
    exit 1
  fi

  local http_code=$(echo "$response" | tail -1)
  local body=$(echo "$response" | sed '$d')
  local end_time=$(date +%s)
  local elapsed=$((end_time - start_time))

  if [ "$http_code" = "200" ]; then
    echo "✓ Sync complete (${elapsed}s)"
    echo ""
    echo "$body" | jq -r '
      "  Global Index: \(.globalScore)",
      "  Categories:",
      (.categoryScores | to_entries | sort_by(.value) | .[] | "    \(.key): \(.value)")
    ' 2>/dev/null || echo "$body"
  elif [ "$http_code" = "401" ]; then
    echo "✗ Unauthorized — check CRON_SECRET in .env"
    exit 1
  elif [ "$http_code" = "000" ]; then
    echo "✗ Could not connect — is the dev server running? (./doom dev)"
    exit 1
  else
    echo "✗ Failed (HTTP ${http_code})"
    echo "$body" | jq . 2>/dev/null || echo "$body"
    exit 1
  fi
}

cmd_dev() {
  npm run dev
}

cmd_status() {
  supabase status
}

cmd_studio() {
  echo "http://127.0.0.1:54333"
}

cmd_db() {
  docker exec -it supabase_db_doomsd psql -U postgres -d postgres
}

if [ $# -eq 0 ]; then
  usage
  exit 1
fi

case "$1" in
  up)      cmd_up ;;
  down)    cmd_down ;;
  migrate) cmd_migrate ;;
  wipe)    cmd_wipe ;;
  sync)    cmd_sync ;;
  dev)     cmd_dev ;;
  status)  cmd_status ;;
  studio)  cmd_studio ;;
  db)      cmd_db ;;
  *)       echo "Unknown command: $1"; usage; exit 1 ;;
esac
